{
  "description": "Updates an existing system key within your Fivetran account.",
  "path": "/v1/system-keys/{keyId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "keyId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the system key within your Fivetran account.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "request_body_schema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "The system key name within the account"
      },
      "permissions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "resource_type": {
              "type": "string",
              "description": "The resource type for the permission",
              "enum": [
                "ACCOUNT",
                "USER",
                "WEBHOOK",
                "TEAM",
                "ROLES",
                "DESTINATION",
                "TRANSFORMATION",
                "REMOTE_EXECUTION_AGENT",
                "CONNECTOR"
              ]
            },
            "access_level": {
              "type": "string",
              "description": "The access level for the permission",
              "enum": [
                "NONE",
                "READ",
                "MANAGE"
              ]
            },
            "resource_filter": {
              "type": "object",
              "properties": {
                "ids": {
                  "type": "array",
                  "description": "The IDs of managed entities",
                  "items": {
                    "type": "string"
                  }
                },
                "group_ids": {
                  "type": "array",
                  "description": "The IDs of managed groups",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}