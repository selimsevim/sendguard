{
  "description": "Creates a new system key with your Fivetran account.",
  "path": "/v1/system-keys",
  "method": "POST",
  "request_body_schema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "The system key name within the account"
      },
      "expiration_period": {
        "type": "string",
        "description": "The system key's expiration period",
        "enum": [
          "ONE_WEEK",
          "ONE_MONTH",
          "THREE_MONTHS",
          "SIX_MONTHS",
          "INFINITE"
        ]
      },
      "permissions": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "resource_type": {
              "type": "string",
              "description": "The resource type for the permission",
              "enum": [
                "ACCOUNT",
                "USER",
                "WEBHOOK",
                "TEAM",
                "ROLES",
                "DESTINATION",
                "TRANSFORMATION",
                "REMOTE_EXECUTION_AGENT",
                "CONNECTOR"
              ]
            },
            "access_level": {
              "type": "string",
              "description": "The access level for the permission",
              "enum": [
                "NONE",
                "READ",
                "MANAGE"
              ]
            },
            "resource_filter": {
              "type": "object",
              "properties": {
                "ids": {
                  "type": "array",
                  "description": "The IDs of managed entities",
                  "items": {
                    "type": "string"
                  }
                },
                "group_ids": {
                  "type": "array",
                  "description": "The IDs of managed groups",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}