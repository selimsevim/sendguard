{
  "description": "Creates a new private link in your Fivetran account. \n\n> NOTE: See the [Set Up a Connection With Private Links tutorial](/docs/rest-api/tutorials/set-up-connection-with-private-links) to learn how to use this endpoint to set up a [database connection](/docs/connectors/databases) with [private networking](/docs/using-fivetran/features#privatenetworking).\n",
  "path": "/v1/private-links",
  "method": "POST",
  "request_body_schema": {
    "required": [
      "config",
      "name",
      "region",
      "service"
    ],
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Private link name"
      },
      "region": {
        "type": "string",
        "description": "Data processing location. This is where Fivetran will operate and run computation on data.",
        "enum": [
          "GCP_US_EAST4",
          "GCP_US_WEST1",
          "GCP_US_CENTRAL1",
          "GCP_EUROPE_WEST3",
          "GCP_AUSTRALIA_SOUTHEAST1",
          "GCP_NORTHAMERICA_NORTHEAST1",
          "GCP_EUROPE_WEST2",
          "GCP_ASIA_SOUTHEAST1",
          "GCP_ASIA_SOUTHEAST2",
          "GCP_ASIA_SOUTH1",
          "GCP_ASIA_NORTHEAST1",
          "AWS_US_EAST_1",
          "AWS_US_EAST_2",
          "AWS_US_WEST_2",
          "AWS_AP_NORTHEAST_1",
          "AWS_AP_SOUTHEAST_1",
          "AWS_AP_SOUTHEAST_2",
          "AWS_EU_CENTRAL_1",
          "AWS_EU_WEST_1",
          "AWS_EU_WEST_2",
          "AWS_AP_SOUTH_1",
          "AWS_CA_CENTRAL_1",
          "AWS_US_GOV_WEST_1",
          "AZURE_EASTUS2",
          "AZURE_AUSTRALIAEAST",
          "AZURE_UKSOUTH",
          "AZURE_WESTEUROPE",
          "AZURE_CENTRALUS",
          "AZURE_CANADACENTRAL",
          "AZURE_UAENORTH",
          "AZURE_SOUTHEASTASIA",
          "AZURE_EASTUS",
          "AZURE_JAPANEAST",
          "AZURE_CENTRALINDIA"
        ]
      },
      "service": {
        "type": "string",
        "description": "The name for the service type within the Fivetran system.",
        "enum": [
          "DATABRICKS_AWS",
          "SNOWFLAKE_AWS",
          "REDSHIFT_AWS",
          "SOURCE_AWS",
          "DATABRICKS_AZURE",
          "SNOWFLAKE_AZURE",
          "ONELAKE_AZURE",
          "POSTGRES_WAREHOUSE_AZURE",
          "SQL_DATA_WAREHOUSE_AZURE",
          "SOURCE_AZURE",
          "SNOWFLAKE_GCP",
          "SOURCE_GCP",
          "DATABRICKS_GCP"
        ]
      }
    },
    "discriminator": {
      "propertyName": "service",
      "mapping": {
        "DATABRICKS_AWS": "#/components/schemas/databricks_aws_PrivateLinkCreateRequest",
        "SNOWFLAKE_AWS": "#/components/schemas/snowflake_aws_PrivateLinkCreateRequest",
        "REDSHIFT_AWS": "#/components/schemas/redshift_aws_PrivateLinkCreateRequest",
        "SOURCE_AWS": "#/components/schemas/source_aws_PrivateLinkCreateRequest",
        "DATABRICKS_AZURE": "#/components/schemas/databricks_azure_PrivateLinkCreateRequest",
        "SNOWFLAKE_AZURE": "#/components/schemas/snowflake_azure_PrivateLinkCreateRequest",
        "ONELAKE_AZURE": "#/components/schemas/onelake_azure_PrivateLinkCreateRequest",
        "POSTGRES_WAREHOUSE_AZURE": "#/components/schemas/postgres_warehouse_azure_PrivateLinkCreateRequest",
        "SQL_DATA_WAREHOUSE_AZURE": "#/components/schemas/sql_data_warehouse_azure_PrivateLinkCreateRequest",
        "SOURCE_AZURE": "#/components/schemas/source_azure_PrivateLinkCreateRequest",
        "SNOWFLAKE_GCP": "#/components/schemas/snowflake_gcp_PrivateLinkCreateRequest",
        "SOURCE_GCP": "#/components/schemas/source_gcp_PrivateLinkCreateRequest",
        "DATABRICKS_GCP": "#/components/schemas/databricks_gcp_PrivateLinkCreateRequest"
      }
    }
  }
}