{
  "description": "Creates a new transformation.",
  "path": "/v1/transformations",
  "method": "POST",
  "request_body_schema": {
    "type": "object",
    "properties": {
      "schedule": {
        "required": [
          "schedule_type"
        ],
        "type": "object",
        "properties": {
          "cron": {
            "type": "array",
            "description": "Cron schedule: list of CRON strings.",
            "items": {
              "type": "string"
            }
          },
          "interval": {
            "type": "integer",
            "description": "The interval in minutes",
            "format": "int32"
          },
          "smart_syncing": {
            "type": "boolean",
            "description": "The boolean flag that enables the Smart Syncing schedule"
          },
          "connection_ids": {
            "uniqueItems": true,
            "type": "array",
            "description": "The list of connection IDs that the Transformation for dbt Core depends on when using the integrated schedule (`schedule_type: INTEGRATED`) or custom schedules (`schedule_type: TIME_OF_DAY` or `schedule_type: INTERVAL`)  with smart syncing enabled (`smart_syncing: true`). These connections must belong to the same group as the dbt project. This field should not be used for Quickstart transformations.",
            "items": {
              "type": "string"
            }
          },
          "schedule_type": {
            "type": "string",
            "description": "The schedule type. The following values are supported: 'INTEGRATED', 'TIME_OF_DAY', 'INTERVAL', 'CRON'",
            "enum": [
              "INTEGRATED",
              "TIME_OF_DAY",
              "INTERVAL",
              "CRON"
            ]
          },
          "days_of_week": {
            "uniqueItems": true,
            "type": "array",
            "description": "The set of days of the week, where an empty set represents a daily schedule",
            "items": {
              "type": "string",
              "enum": [
                "MONDAY",
                "TUESDAY",
                "WEDNESDAY",
                "THURSDAY",
                "FRIDAY",
                "SATURDAY",
                "SUNDAY"
              ]
            }
          },
          "transformation_ids": {
            "uniqueItems": true,
            "type": "array",
            "description": "The list of the transformation identifiers to be used for the integrated schedule or custom scheduling with smart syncing enabled",
            "items": {
              "type": "string"
            }
          },
          "time_of_day": {
            "type": "string",
            "description": "The time of the day the transformation should be launched at. The following values are supported: '00:00', '00:30', '01:00', '01:30', '02:00', '02:30', '03:00', '03:30', '04:00', '04:30', '05:00', '05:30', '06:00', '06:30', '07:00', '07:30', '08:00', '08:30', '09:00', '09:30', '10:00', '10:30', '11:00', '11:30', '12:00', '12:30', '13:00', '13:30', '14:00', '14:30', '15:00', '15:30', '16:00', '16:30', '17:00', '17:30', '18:00', '18:30', '19:00', '19:30', '20:00', '20:30', '21:00', '21:30', '22:00', '22:30', '23:00', '23:30'"
          }
        }
      },
      "type": {
        "type": "string",
        "enum": [
          "DBT_CORE",
          "QUICKSTART"
        ]
      },
      "paused": {
        "type": "boolean"
      }
    },
    "discriminator": {
      "propertyName": "type",
      "mapping": {
        "DBT_CORE": "#/components/schemas/DBT_CORE_NewTransformationRequest",
        "QUICKSTART": "#/components/schemas/QUICKSTART_NewTransformationRequest"
      }
    }
  }
}