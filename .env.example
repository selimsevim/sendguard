# --- Fivetran API (Basic auth pair from fivetran.com -> Settings -> API) ---
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=
# Required for sync_connection / Activations trigger (MCP gates non-GET calls)
FIVETRAN_ALLOW_WRITES=true
# Connection id of the SFMC -> BigQuery connector (from Fivetran dashboard URL)
FIVETRAN_SFMC_CONNECTION_ID=
# Activations (reverse ETL) uses the Census API: https://app.getcensus.com
# Get the workspace API token from the Activations workspace settings in Fivetran
FIVETRAN_ACTIVATIONS_TOKEN=
# Integer sync id -- leave blank, agent can discover it via list_activation_syncs
FIVETRAN_ACTIVATION_SYNC_ID=

# --- Google Cloud / BigQuery (uses ADC: run `gcloud auth application-default login`) ---
GOOGLE_CLOUD_PROJECT=fivetran-499011
BIGQUERY_LOCATION=US
# Dataset the SFMC connector lands in (check Fivetran destination schema name)
BQ_SFMC_DATASET=
BQ_CENSUS_DATASET=CENSUS

# --- Gemini (AI Studio key, or set GOOGLE_GENAI_USE_VERTEXAI=true for Vertex) ---
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false

# --- Salesforce Marketing Cloud (installed package, client credentials) ---
SFMC_SUBDOMAIN=
SFMC_CLIENT_ID=
SFMC_CLIENT_SECRET=
SFMC_ACCOUNT_ID=
# External key of the audience DE and of the send-flag DE / automation
SFMC_AUDIENCE_DE_KEY=
SFMC_SENDFLAG_DE_KEY=
